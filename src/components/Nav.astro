---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}/bowling`, label: "Bowling" },
  { href: `${base}/parties`, label: "Parties" },
  { href: `${base}/rythmz-lounge`, label: "Rythmz Lounge" },
  { href: `${base}/arcade`, label: "Arcade" },
  { href: `${base}/food`, label: "Food" },
  { href: `${base}/schedule`, label: "Schedule" },
  { href: `${base}/pricing`, label: "Pricing" },
  { href: `${base}/contact`, label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-near-black/80 backdrop-blur">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href={base || "/"} class="text-xl font-bold tracking-tight text-electric-yellow neon">
      ANTELOPE <span class="text-antelope-red">LANES</span>
    </a>
    <ul class="hidden items-center gap-6 md:flex">
      {links.map((l) => (
        <li>
          <a href={l.href} class="text-sm text-white/80 transition hover:text-neon-cyan">{l.label}</a>
        </li>
      ))}
    </ul>
    <a
      href="tel:9287727501"
      class="rounded-full border border-neon-cyan px-4 py-2 text-sm font-semibold text-neon-cyan neon-border transition hover:bg-neon-cyan/10"
    >
      Call to Book
    </a>
  </nav>
</header>
