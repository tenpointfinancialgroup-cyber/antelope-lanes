---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Arcade — Antelope Lanes">
  <PageHero
    eyebrow="Games · Pool tables"
    title="Arcade"
    accent="text-electric-yellow"
    body="Something for every age — plus a pair of pool tables for the grown-ups."
  />
  <section class="mx-auto max-w-5xl px-4 py-16 text-white/70">
    <p class="text-center">Short arcade page (photos + highlights) lands in design/build once photography is captured.</p>
  </section>
</Layout>
