---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Bowling — Antelope Lanes">
  <PageHero
    eyebrow="24 full-size lanes"
    title="Bowling"
    accent="text-neon-cyan"
    body="Open play, leagues, junior leagues, tournaments, and GLOW cosmic-bowl nights."
  />
  <section class="mx-auto max-w-5xl px-4 py-16 text-white/70">
    <p class="text-center">Full bowling content — open hours, league signup, junior schedule, cosmic-bowl nights, lane reservations — lands in the design/build phase.</p>
  </section>
</Layout>
