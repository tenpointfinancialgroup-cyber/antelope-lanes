---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Contact — Antelope Lanes">
  <PageHero
    eyebrow="Find us · Call us · Email us"
    title="Contact"
    accent="text-neon-cyan"
    body="Right off Highway 89A in Prescott Valley."
  />
  <section class="mx-auto max-w-3xl px-4 py-16 text-center text-white/80">
    <p class="text-2xl font-bold text-white">Antelope Lanes</p>
    <p class="mt-2">6301 E. 2nd St.<br/>Prescott Valley, AZ 86314</p>
    <p class="mt-4">
      <a href="tel:9287727501" class="text-neon-cyan hover:underline">928-772-7501</a><br/>
      <a href="mailto:antelopelanesbowling@gmail.com" class="text-neon-cyan hover:underline">antelopelanesbowling@gmail.com</a>
    </p>
    <p class="mt-12 text-sm text-white/50">Map embed + contact form land in design/build phase.</p>
  </section>
</Layout>
