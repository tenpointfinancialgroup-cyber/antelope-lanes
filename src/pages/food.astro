---

<Layout title="Food & Deli Menu — Antelope Lanes" description="The full Antelope Lanes deli menu — starters, wings, burgers, pizza, sandwiches, kids meals and more in Prescott Valley.">
  <PageHero
    eyebrow="Deli · Snacks · Drinks"
    title="Food"
    accent="text-hot-orange"
    body="Real food, not just bowling-alley fare. Order at the counter, we bring it to your lane."
  />

  <!-- SPECIALS -->
  <section class="mx-auto max-w-5xl px-4 pt-16">
    <div class="rounded-2xl border border-antelope-red/40 bg-dark-slate p-6 md:p-8">
      <h2 class="text-2xl font-black uppercase tracking-tight text-antelope-red neon">Current Specials</h2>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {specials.map((s) => (
          <li class="flex items-baseline justify-between gap-4 rounded-xl bg-near-black/60 px-4 py-3">
            <span class="font-semibold text-white">{s.name}</span>
            <span class="shrink-0 font-bold text-electric-yellow">{s.price}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FULL MENU -->
  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {sections.map((sec) => (
        <div class="rounded-2xl border border-white/10 bg-dark-slate p-6">
          <h2 class:list={["text-2xl font-black uppercase tracking-tight neon", sec.color]}>{sec.title}</h2>
          {sec.note && <p class="mt-1 text-xs uppercase tracking-widest text-white/50">{sec.note}</p>}
          <ul class="mt-4 space-y-3">
            {sec.items.map((item) => (
              <li>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="font-semibold text-white">{item.name}</span>
                  <span class="h-px flex-1 self-center bg-white/10"></span>
                  <span class:list={["shrink-0 font-bold", sec.color]}>{item.price}</span>
                </div>
                {item.desc && <p class="mt-0.5 text-sm text-white/60">{item.desc}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="mt-10 text-center text-xs text-white/40">
      Consuming raw or undercooked meat, poultry, seafood, shellfish or eggs may increase your risk of foodborne illness.
    </p>
  </section>
</Layout>
