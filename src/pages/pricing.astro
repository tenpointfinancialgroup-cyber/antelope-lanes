---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Pricing — Antelope Lanes">
  <PageHero
    eyebrow="Lanes · Parties · Leagues"
    title="Pricing"
    accent="text-electric-yellow"
    body="Clear pricing for lanes, parties, and league play."
  />
  <section class="mx-auto max-w-5xl px-4 py-16 text-white/70">
    <p class="text-center">Full pricing tables (per-lane, party packages, league fees) land in design/build phase — pending current pricing sheet from client.</p>
  </section>
</Layout>
