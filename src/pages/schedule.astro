---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Schedule, Hours & Specials — Antelope Lanes">
  <PageHero
    eyebrow="Hours · Specials · Cosmic nights"
    title="Schedule"
    accent="text-neon-violet"
    body="Daily hours, weekly specials, league schedule, and signature events."
  />
  <section class="mx-auto max-w-5xl px-4 py-16 text-white/70">
    <p class="text-center">Hours, weekly specials carousel, league calendar, and cosmic-bowl event nights land in design/build phase.</p>
  </section>
</Layout>
